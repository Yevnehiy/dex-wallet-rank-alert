# Copy to .env and fill in. The scanner reads this file at startup.
# .env is gitignored — never commit real values.

# Cloudflare — used by the scanner to write candidates/prices/heartbeat into KV,
# and by update-token-list.js to seed the token list.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
KV_NAMESPACE_ID=

# CoinGecko — only required by scripts/update-token-list.js (pool discovery).
# The scanner itself runs on the free GeckoTerminal API and needs no key.
COINGECKO_API_KEY=
